generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./prisma/dev.db"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String
  nickname      String?
  avatar        String?
  theme         String    @default("warm")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  comments      Comment[]
  travelEntries TravelEntry[]
  photoEntries  PhotoEntry[]
}

model BirthdayVideo {
  id          String   @id @default(cuid())
  year        Int      @unique
  title       String
  bvid        String   // B站视频BV号
  description String?
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TravelEntry {
  id          String   @id @default(cuid())
  title       String
  content     String   // 富文本内容
  location    String?
  travelDate  DateTime
  coverImage  String?
  images      String   // 图片数组，JSON存储
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  comments    Comment[]
}

model PhotoEntry {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  photoDate   DateTime?
  category    String   // 分类：风景、人物、生活等
  tags        String   // 标签数组，JSON存储
  thoughts    String?  // 摄影心得
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  comments    Comment[]
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  // Polymorphic relations
  travelEntryId String?
  travelEntry   TravelEntry? @relation(fields: [travelEntryId], references: [id], onDelete: Cascade)
  
  photoEntryId  String?
  photoEntry    PhotoEntry?  @relation(fields: [photoEntryId], references: [id], onDelete: Cascade)
}
