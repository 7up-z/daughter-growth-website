generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String
  nickname      String?
  avatar        String?
  theme         String    @default("warm")
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  comments      Comment[]
  travelEntries TravelEntry[]
  photoEntries  PhotoEntry[]
}

model BirthdayVideo {
  id          String   @id @default(cuid())
  year        Int
  title       String
  bvid        String
  description String?
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([year])
}

model TravelEntry {
  id          String   @id @default(cuid())
  title       String
  content     String
  location    String?
  travelDate  DateTime
  coverImage  String?
  images      String   @default("[]")
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  comments    Comment[]
}

model PhotoEntry {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  photoDate   DateTime?
  category    String
  tags        String   @default("[]")
  thoughts    String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  comments    Comment[]
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  travelEntryId String?
  travelEntry   TravelEntry? @relation(fields: [travelEntryId], references: [id], onDelete: Cascade)
  
  photoEntryId  String?
  photoEntry    PhotoEntry?  @relation(fields: [photoEntryId], references: [id], onDelete: Cascade)
}
