[project]
sub_id = "e3221fcc"
name = "daughter-growth-website"
requires = ["nodejs-24"]
entrypoint = "server.js"
project_type = "web"

[preview]
preview_enable = "enabled"

[dev]
build = ["bash", "scripts/coze-preview-build.sh"]
run = ["bash", "scripts/coze-preview-run.sh"]

[deploy]
build = ["bash", ".cozeproj/scripts/deploy_build.sh"]
run = ["bash", ".cozeproj/scripts/deploy_run.sh"]

[deploy.profile]
kind = "service"
flavor = "web"

[deploy.backend]
enabled = true

[subprojects]
path = ["."]
